<dataumum>

 <param kunci = "GANTI_TIMELOOP">
      <timeloop type="TIPE">
        <link>
          <animated type="angle">
            <waypoint time="0s" before="clamped" after="clamped">
              <angle value="0.000000"/>
            </waypoint>
            <waypoint time="0.40000001s" before="clamped" after="clamped">
              <angle value="360.000000"/>
            </waypoint>
          </animated>
        </link>
        <link_time>
          <time value="0s"/>
        </link_time>
        <local_time>
          <time value="0s"/>
        </local_time>
        <duration>
          <time value="WAKTU"/>
        </duration>
      </timeloop>
    </param>

<data_bonedeformation_param kunci = "BONE_deformation_param">
  <param name="point1">
    <vector>
      <x>-4.0000000000</x>
      <y>4.0000000000</y>
    </vector>
  </param>
  <param name="point2">
    <vector>
      <x>4.0000000000</x>
      <y>-4.0000000000</y>
    </vector>
  </param>
  <param name="x_subdivisions">
    <integer value="32"/>
  </param>
  <param name="y_subdivisions">
    <integer value="32"/>
  </param>
  <param name="blend_method">
      <integer value="1" static="true"/>
  </param>
</data_bonedeformation_param>

  <entry kunci = "BONE_deformation">
    <composite type="pair_bone_object_bone_object">
      <first>
        <bone type="bone_object" guid="GUID_baru"/>
      </first>
      <second>
        <bone type="bone_object" guid="GUID_awal"/>
      </second>
    </composite>
  </entry>

  <data kunci = "BONE_shape">
    <display>
      <integer value="1"/>
    </display>
  </data>
  
  <data kunci ="CU_jump">
	<jump>
    <integer value="10"/>
  </jump>
  </data>

  <data2 kunci ="CU_influence">
  <influence>
    <real value="100.0000000000"/>
  </influence>
  </data2>
  
</dataumum>